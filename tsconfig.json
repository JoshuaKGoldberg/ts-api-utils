{
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"outDir": "lib",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2022",
		"stripInternal": true,
		"verbatimModuleSyntax": true,
		"types": ["node"],
		"moduleDetection": "force",
		"isolatedModules": true
	},
	"include": ["src", "typings"]
}
